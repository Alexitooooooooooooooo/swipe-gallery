{
  "expo": {
    "name": "swipe-gallery",
    "slug": "swipe-gallery",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Permite a la app acceder a tus fotos para que puedas deslizar y limpiar tu galería.",
          "savePhotosPermission": "Permite a la app guardar o modificar las fotos de tu galería.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "photo"
          ]
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/unnamed.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.swipegallery"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "package": "com.anonymous.swipegallery"
    },
    "extra": {
      "eas": {
        "projectId": "23f93cec-78d1-4a29-8f4f-9aa985bb2b73"
      }
    }
  }
}
